# Production defaults. Real DATABASE_URL / REDIS_URL come from
# /etc/ynot/secrets.env via Docker env_file.
# NODE_ENV omitted — Next.js / Node set it to "production" automatically.
NEXT_PUBLIC_SITE_URL="https://ynot.london"

# NEXTAUTH_SECRET injected via /etc/ynot/secrets.env in prod (Phase Deploy & Ops).
# RESEND_API_KEY / RESEND_FROM also injected at runtime; see .env.example.
